// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi ke Expense
  expenses Expense[]
  // Relasi ke Budget
  budgets  Budget[]
}

model Expense {
  id        String    @id @default(cuid())
  title     String
  amount    Float
  category  String    // "food", "transport", dll
  date      DateTime  @default(now())
  note      String?   // Tanda ? = optional (boleh null)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Foreign key ke User
  userId    String
  user      User      @relation(fields: [userId], references: [id])
}

model Budget {
  id        String   @id @default(cuid())
  amount    Float
  category  String   // "all" untuk seluruh pengeluaran, atau kategori spesifik seperti "food", "transport"
  month     Int      // 1-12
  year      Int
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, month, year]) // Satu user hanya boleh punya satu budget per kategori/bulan
}
